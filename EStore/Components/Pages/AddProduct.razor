@page "/add_product"

@using EStore.Forms.Product
@using EStore.Services.Ecommerce
@using EStore.Services.Database
@using EStore.Services.Products
@using Microsoft.AspNetCore.Components

@inject IEcommerceService EcommerceService
@inject IProductService ProductService
@inject NavigationManager NavigationManager

<PageTitle>LogiSale - Add Product</PageTitle>

<div class="add-product-container">
    <div class="form-card section-card">
        <div class="form-card-header mb-4 text-center">
            <div class="form-icon-wrapper mb-3">
                <svg class="form-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h2>Add New Store Item</h2>
            <p class="text-secondary m-0 mt-1">Populate details to generate a custom product connected to your storefront catalog.</p>
        </div>

        @if (Success == "true")
        {
            <div class="alert alert-success text-center mb-4" role="alert">
                Product added successfully!
            </div>
        }

        <EditForm Model="ProductCreationModel" OnValidSubmit="HandleSubmitAsync" FormName="ProductCreationForm" Enhance>
            <DataAnnotationsValidator />

            <div class="form-group mb-3">
                <label for="name" class="form-label">Product Name</label>
                <InputText id="name" @bind-Value="ProductCreationModel.Name" class="form-control" placeholder="e.g. Medium White Running Shoes" />
                <ValidationMessage For="@(() => ProductCreationModel.Name)" />
            </div>

            <div class="form-group mb-3">
                <label for="description" class="form-label">Description</label>
                <InputTextArea id="description" @bind-Value="ProductCreationModel.Description" class="form-control" rows="4" placeholder="A description of the product." />
                <ValidationMessage For="@(() => ProductCreationModel.Description)" />
            </div>

            <div class="form-group mb-4">
                <label for="price" class="form-label">Price (USD)</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <InputNumber id="price" 
                        @bind-Value="ProductCreationModel.Price" 
                        @bind-Value:format="F2"
                        step="0.01" 
                        class="form-control"
                        placeholder="0.00" />
                </div>
                <ValidationMessage For="@(() => ProductCreationModel.Price)" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2 py-3 mt-2">
                <svg style="width: 20px; height: 20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Publish Store Item
            </button>
        </EditForm>
    </div>
</div>

@code {
    // Instantiate the model to bind form data
    [SupplyParameterFromForm]
    public ProductCreationModel ProductCreationModel { get; set; } = default!;

    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    protected override void OnInitialized()
    {
        ProductCreationModel ??= new(); 
    }

    private async Task HandleSubmitAsync()
    {
        Product product = await ProductService.AddProductAsync(
            ProductCreationModel.Name,
            ProductCreationModel.Price,
            ProductCreationModel.Description
        );

        NavigationManager.NavigateTo("/add_product?success=true");
    }
}
