@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <header class="top-header px-4 d-flex justify-content-between align-items-center">
            <div class="header-status d-none d-sm-flex align-items-center gap-2">
                <span class="status-indicator"></span>
                <span class="status-text">LogiSale Storefront: Open</span>
            </div>
            <div class="header-actions d-flex align-items-center gap-3">
                <a class="header-link" href="products">
                    <span class="badge-shopping">Shop All Items</span>
                </a>
                <div class="user-avatar">JD</div>
            </div>
        </header>

        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

<NotificationContainer />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
