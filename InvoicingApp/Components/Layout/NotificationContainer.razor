@using InvoicingApp.Services.Notification
@inject NotificationService NotificationService
@implements IDisposable

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055;">
    @foreach (var toast in NotificationService.Toasts)
    {
        <div class="toast show align-items-center text-white @GetBgColor(toast.Level) border-0 mb-2" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @toast.Message
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" 
                        @onclick="() => RemoveToast(toast)"></button>
            </div>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        NotificationService.OnNotify += StateHasChanged;
    }

    private void RemoveToast(ToastMessage toast)
    {
        NotificationService.Toasts.Remove(toast);
    }

    private string GetBgColor(ToastLevel level) => level switch
    {
        ToastLevel.Success => "bg-success",
        ToastLevel.Warning => "bg-warning text-dark",
        ToastLevel.Error => "bg-danger",
        _ => "bg-primary"
    };

    public void Dispose()
    {
        NotificationService.OnNotify -= StateHasChanged;
    }
}
