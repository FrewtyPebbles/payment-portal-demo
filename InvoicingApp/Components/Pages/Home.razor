@page "/"

<PageTitle>LogiSale Store - Premium Modern Essentials</PageTitle>

<div class="home-container">
    <!-- Hero Header Section -->
    <div class="hero-section text-center py-5 px-3 mb-5">
        <span class="badge-new mb-3">Fresh Arrivals Weekly</span>
        <h1 class="hero-title mt-2 mb-3">Curated Quality, Delivered Daily</h1>
        <p class="hero-subtitle mx-auto text-secondary">
            Welcome to LogiSale Store. Explore our handpicked collection of digital goods, premium assets, and modern essentials designed to elevate your everyday workflow.
        </p>
        <div class="d-flex justify-content-center gap-3 mt-4 flex-wrap">
            <a href="products" class="btn btn-primary btn-lg px-4 d-flex align-items-center gap-2">
                Explore Our Collection
            </a>
            <a href="add_product" class="btn btn-secondary btn-lg px-4">
                Add Store Item
            </a>
        </div>
    </div>

    <!-- Friendly Trust Badges -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon-wrapper purple-glow">
                    <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <div class="stat-info">
                    <span class="stat-label">Instant Delivery</span>
                    <span class="stat-val">Immediate Access</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon-wrapper emerald-glow">
                    <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
                <div class="stat-info">
                    <span class="stat-label">Safe Payments</span>
                    <span class="stat-val">Fully Encrypted</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-icon-wrapper blue-glow">
                    <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                </div>
                <div class="stat-info">
                    <span class="stat-label">Premium Support</span>
                    <span class="stat-val">Dedicated 24/7 Care</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Collection Highlights -->
    <h2 class="section-title mb-4 text-center">Engineered for Delight</h2>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="feature-card h-100">
                <h3 class="feature-title d-flex align-items-center gap-2">
                    <span class="feature-num">01</span> Curated Catalog
                </h3>
                <p class="feature-text text-secondary">
                    Discover handpicked digital items, productivity tools, and assets designed by top creators. We verify every product to guarantee outstanding quality.
                </p>
                <a href="products" class="feature-link">Browse collection &rarr;</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="feature-card h-100">
                <h3 class="feature-title d-flex align-items-center gap-2">
                    <span class="feature-num">02</span> Seamless Experience
                </h3>
                <p class="feature-text text-secondary">
                    Add selected products to your shopping basket, review quantities in a lightweight interactive cart, and breeze through checkout in seconds.
                </p>
                <a href="cart" class="feature-link">View your basket &rarr;</a>
            </div>
        </div>
    </div>
</div>
