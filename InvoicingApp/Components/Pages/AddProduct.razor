@page "/add_product"

@using InvoicingApp.Forms.Product
@using InvoicingApp.Services.Notification
@using InvoicingApp.Services.Ecommerce
@using InvoicingApp.Services.Database

@inject NotificationService NotificationService
@inject IEcommerceService EcommerceService

<div class="add-product-container">
    <div class="form-card section-card">
        <div class="form-card-header mb-4 text-center">
            <div class="form-icon-wrapper mb-3">
                <svg class="form-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h2>Add New Store Item</h2>
            <p class="text-secondary m-0 mt-1">Populate details to generate a custom product connected to your storefront catalog.</p>
        </div>

        <EditForm Model="_productCreationModel" OnValidSubmit="HandleSubmitAsync" FormName="ProductCreationForm">
            <DataAnnotationsValidator />

            <div class="form-group mb-3">
                <label for="name" class="form-label">Product Name</label>
                <InputText id="name" @bind-Value="_productCreationModel.Name" class="form-control" placeholder="e.g. Premium Consulting Hour" />
                <ValidationMessage For="@(() => _productCreationModel.Name)" />
            </div>

            <div class="form-group mb-3">
                <label for="description" class="form-label">Description</label>
                <InputTextArea id="description" @bind-Value="_productCreationModel.Description" class="form-control" rows="4" placeholder="Brief outline detailing the service deliverables or digital asset benefits." />
                <ValidationMessage For="@(() => _productCreationModel.Description)" />
            </div>

            <div class="form-group mb-4">
                <label for="price" class="form-label">Price Rate (USD)</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <InputNumber id="price" 
                        @bind-Value="_productCreationModel.Price" 
                        @bind-Value:format="F2"
                        step="0.01" 
                        class="form-control"
                        placeholder="0.00" />
                </div>
                <ValidationMessage For="@(() => _productCreationModel.Price)" />
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 d-flex align-items-center justify-content-center gap-2 py-3 mt-2">
                <svg style="width: 20px; height: 20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Publish Store Item
            </button>
        </EditForm>
    </div>
</div>

@code {
    // Instantiate the model to bind form data
    private ProductCreationModel _productCreationModel = new();

    private async void HandleSubmitAsync()
    {
        Product product = await EcommerceService.CreateProductAsync(_productCreationModel.Name, _productCreationModel.Price, _productCreationModel.Description);
        NotificationService.ShowToast($"Product {product.Name} added successfully.", ToastLevel.Success);
        
        // Reset model for clean next input
        _productCreationModel = new();
        StateHasChanged();
    }
}
